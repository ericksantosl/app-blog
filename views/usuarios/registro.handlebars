{{#each erros}}
    <div class="alert alert-danger">{{texto}}</div>
{{else}}

{{/each}}

<h3>Criar sua conta: </h3>
<div class="card">
    <div class="card-body">
        <form action="" method="post">
            <label for="nome">Nome:</label>
                <input type="text" name="nome" class="form-control" required>
            <label for="email" class="mt-2">Email: </label>
                <input type="email" name="email" class="form-control" required>
            <label for="senha" class="mt-2">Senha: </label>
                <input type="password" name="senha" class="form-control" required>
            <label for="senha2" class="mt-2">Repita a sua senha: </label>
                <input type="password" name="senha2" class="form-control" required>
            <button type="submit" class="btn btn-success mt-4">Criar conta</button>
        </form>
    </div>
</div>